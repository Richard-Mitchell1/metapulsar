   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Understanding PTA releases\n",
    "\n",
    "Pre-set PTA data releases define how to discover and process files for a specific PTA collaboration.\n",
    "\n",
    "The file discovery service has some pre-set release regular expressions that we can use for dataset discovery\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Existing PTAs: ['epta_dr1_v2_2', 'epta_dr2', 'inpta_dr1', 'mpta_dr1', 'nanograv_12y', 'nanograv_15y', 'nanograv_9y', 'ppta_dr2']\n",
      "\n",
      "Example PTA configuration structure:\n",
      "  base_dir: /data/custom_pta/\n",
      "  par_pattern: ([BJ]\\d{4}[+-]\\d{2,4})_custom\\.par\n",
      "  tim_pattern: ([BJ]\\d{4}[+-]\\d{2,4})_custom\\.tim\n",
      "  timing_package: pint\n",
      "  priority: 1\n",
      "  description: Custom PTA for demonstration\n",
      "\n",
      "Configuration fields:\n",
      "  base_dir: Directory where PTA files are stored\n",
      "  par_pattern: Regex pattern for par files\n",
      "  tim_pattern: Regex pattern for tim files\n",
      "  timing_package: Timing package to use (pint, tempo2)\n",
      "  priority: Priority for file selection (higher = more important)\n",
      "  description: Human-readable description of the PTA\n"
     ]
    }
   ],
   "source": [
    "# Create file discovery service\n",
    "discovery = FileDiscoveryService(working_dir=\"/workspaces/metapulsar\")\n",
    "\n",
    "# List existing PTAs\n",
    "existing_ptas = discovery.list_ptas()\n",
    "print(f\"Existing PTAs: {existing_ptas}\")\n",
    "\n",
    "# Show example configuration structure\n",
    "print(\"\\nExample PTA configuration structure:\")\n",
    "example_layout = {\n",
    "    \"base_dir\": \"/data/custom_pta/\",\n",
    "    \"par_pattern\": r\"([BJ]\\d{4}[+-]\\d{2,4})_custom\\.par\",\n",
    "    \"tim_pattern\": r\"([BJ]\\d{4}[+-]\\d{2,4})_custom\\.tim\",\n",
    "    \"timing_package\": \"pint\",\n",
    "    \"priority\": 1,\n",
    "    \"description\": \"Custom PTA for demonstration\"\n",
    "}\n",
    "\n",
    "for key, value in example_layout.items():\n",
    "    print(f\"  {key}: {value}\")\n",
    "\n",
    "print(\"\\nConfiguration fields:\")\n",
    "print(\"  base_dir: Directory where PTA files are stored\")\n",
    "print(\"  par_pattern: Regex pattern for par files\")\n",
    "print(\"  tim_pattern: Regex pattern for tim files\")\n",
    "print(\"  timing_package: Timing package to use (pint, tempo2)\")\n",
    "print(\"  priority: Priority for file selection (higher = more important)\")\n",
    "print(\"  description: Human-readable description of the PTA\")\n"
   ]
  },
