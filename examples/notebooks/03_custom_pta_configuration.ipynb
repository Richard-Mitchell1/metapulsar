   ],
   "source": [
    "# Add custom PTA directory layout\n",
    "custom_pta_name = \"custom_pta\"\n",
    "custom_config = {\n",
    "    \"base_dir\": \"/data/custom_pta/\",\n",
    "    \"par_pattern\": r\"([BJ]\\d{4}[+-]\\d{2,4})_custom\\.par\",\n",
    "    \"tim_pattern\": r\"([BJ]\\d{4}[+-]\\d{2,4})_custom\\.tim\",\n",
    "    \"timing_package\": \"pint\",\n",
    "    \"priority\": 1,\n",
    "    \"description\": \"Custom PTA for demonstration\"\n",
    "}\n",
    "\n",
    "print(f\"Adding custom PTA layout: {custom_pta_name}\")\n",
    "discovery.add_pta(custom_pta_name, custom_config)\n",
    "print(\"✅ Custom PTA layout added successfully!\")\n",
    "\n",
    "# List all PTAs (including custom one)\n",
    "all_layouts = discovery.list_ptas()\n",
    "print(f\"\\nAll PTA layouts (including custom): {all_layouts}\")\n",
    "print(f\"Total layouts: {len(all_layouts)}\")\n",
    "\n",
    "# Verify custom PTA was added\n",
    "if custom_layout_name in all_layouts:\n",
    "    print(f\"✅ Custom layout '{custom_layout_name}' is now available!\")\n",
    "else:\n",
    "    print(f\"❌ Custom layout '{custom_layout_name}' was not added properly\")\n"
   ]
