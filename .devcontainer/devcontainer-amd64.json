{
  "name": "ipta-metapulsar-analysis Full Precision (AMD64)",
  "build": {
    "dockerfile": "Dockerfile.amd64",
    "platform": "linux/amd64"
  },

  "remoteUser": "vscode",
  //"features": {},
  //"overrideCommand": false,

  "containerEnv": {
    "VIRTUAL_ENV": "/opt/venvs/pta"
  },

  "remoteEnv": {
    "PATH": "/opt/venvs/pta/bin:/opt/software:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
  },

  "postCreateCommand": "echo 'Virtual environment is pre-configured'",
  "postStartCommand": "bash -lc 'source /opt/venvs/pta/bin/activate && pre-commit install --hook-type pre-commit --hook-type pre-push --hook-type commit-msg'",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.vscodevim",
        "ms-vscode-remote.remote-containers",
        "ms-python.python",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "ms-python.pytest",
        "ms-vscode.vscode-json",
        "redhat.vscode-yaml",
        "ms-vscode.makefile-tools",
        "github.vscode-pull-request-github",
        "eamodio.gitlens"
      ]
    }
  },

  "portsAttributes": {
    "5000": { "label": "Web App", "onAutoForward": "notify" }
  }
}

